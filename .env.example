# TaskFlow Environment Configuration
# Copy this file to .env and update with your actual values

# ==================== DATABASE ====================
# PostgreSQL Connection (uncomment to use)
# DATABASE_URL=postgresql://taskflow_user:your_password@localhost:5432/taskflow_db

# For SQLite (default behavior if DATABASE_URL not set)
# No configuration needed - uses taskflow.db by default

# ==================== FLASK ====================
FLASK_ENV=development
FLASK_DEBUG=True

# Change this to a secure random string in production
SECRET_KEY=dev-secret-key-please-change-in-production
JWT_SECRET_KEY=jwt-secret-key-please-change-in-production

# ==================== DATABASE LOGGING ====================
SQLALCHEMY_ECHO=False

# ==================== CORS ====================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5000

# ==================== SERVER ====================
HOST=0.0.0.0
PORT=5000

# ==================== POSTGRESQL (if using with credentials) ====================
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_DB=taskflow_db
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
